# Notification channels - at least one must be set. Both fire if both are set.

# Discord webhook to post "back in stock" alerts to.
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram Bot API credentials.
# 1. Message @BotFather on Telegram -> /newbot -> copy the token it gives you.
# 2. Send any message to your new bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy the "id" under "chat" from the JSON response - that's your chat id.
#    (For a group, add the bot to the group first, send a message there instead.
#     Group ids are negative, e.g. -5469712170.)
# To notify several chats at once (e.g. a private chat AND a group), list the
# ids comma-separated: TELEGRAM_CHAT_ID=123456789,-5469712170
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather
TELEGRAM_CHAT_ID=123456789

# How often to run a full check cycle, in minutes.
CHECK_INTERVAL_MINUTES=10

# Random +/- jitter (in seconds) applied to the interval above, so requests
# don't land on a perfectly predictable cadence.
JITTER_SECONDS=30

# Run the browser headless (true) or with a visible window for debugging (false).
HEADLESS=true

# Per-request timeout in milliseconds, for both page loads and API calls.
REQUEST_TIMEOUT_MS=30000

# Randomized delay range (ms) inserted between checking each target within a cycle.
MIN_DELAY_BETWEEN_TARGETS_MS=2000
MAX_DELAY_BETWEEN_TARGETS_MS=6000

# Where the last-known-status JSON file is stored.
STATE_FILE_PATH=./data/state.json

# debug | info | warn | error
LOG_LEVEL=info

# When true, run a single check cycle and exit instead of looping forever.
# Used for external schedulers (e.g. the GitHub Actions cron workflow) -
# leave this false/unset for a normal always-running deployment.
RUN_ONCE=false

# Override the default Chrome user-agent string if needed.
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
